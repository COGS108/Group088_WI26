    "if len(df_paid) > 5: \n",
    "    X_paid = df_paid[features_h1].fillna(0)\n",
    "    y_paid = df_paid['log_revenue'].fillna(0)\n",
    "    if len(X_paid) > 0:\n",
    "        rf_paid = RandomForestRegressor(n_estimators=100, random_state=42)\n",
    "        rf_paid.fit(X_paid, y_paid)\n",
    "        print(\"\\nPAID GAMES - Feature Importance:\")\n",
    "        for feat, imp in zip(features_h1, rf_paid.feature_importances_):\n",
    "            print(f\"    {feat:15}: {imp:.4f}\")\n",
    "    cv_scores_paid = cross_val_score(rf_paid, X_paid, y_paid, cv=min(5, len(X)), scoring='r2')\n",
    "    print(f\"\\n  {len(cv_scores_paid)}-Fold CV R² with 95% CI: {cv_scores_paid.mean():.4f} (+/- {cv_scores_paid.std()*2:.4f})\")\n",
    "\n",
    "# Free games model\n",
    "if len(df_free) > 5:  \n",
    "    X_free = df_free[features_h1].fillna(0)\n",
    "    y_free = df_free['log_revenue'].fillna(0)\n",
    "    if len(X_free) > 0:\n",
    "        rf_free = RandomForestRegressor(n_estimators=100, random_state=42)\n",
    "        rf_free.fit(X_free, y_free)\n",
    "        print(\"\\nFREE GAMES - Feature Importance:\")\n",
    "        for feat, imp in zip(features_h1, rf_free.feature_importances_):\n",
    "            print(f\"    {feat:15}: {imp:.4f}\")\n",
    "    cv_scores_free = cross_val_score(rf_free, X_free, y_free, cv=min(5, len(X)), scoring='r2')\n",
    "    print(f\"\\n  {len(cv_scores_free)}-Fold CV R² with 95% CI: {cv_scores_free.mean():.4f} (+/- {cv_scores_free.std()*2:.4f})\")"
