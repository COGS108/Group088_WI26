    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# Load data\n",
    "df = pd.read_csv(\"data/02-processed/shooter_performance_data.csv\")\n",
    "\n",
    "# Pre-processing\n",
    "# Create log variables\n",
    "df[\"log_revenue\"] = np.log10(df[\"estimated_revenue\"] + 1)\n",
    "df[\"log_ccu\"] = np.log10(df[\"ccu\"] + 1)\n",
    "df[\"log_search\"] = np.log10(df[\"search_interest\"] + 1)\n",
    "df[\"log_retention\"] = np.log10(df[\"player_retention\"] + 1)\n",
    "df[\"price_category_interaction\"] = df[\"initialprice\"] * df[\"categories_count\"]\n",
    "\n",
    "# Filtered dataframes for specific scatter plots to avoid inactive games\n",
    "df_search_active = df[df[\"search_interest\"] > 0].copy()\n",
    "df_retention_active = df[df[\"player_retention\"] > 0].copy()\n",
    "\n",
    "# Set theme\n",
    "sns.set_theme(style=\"whitegrid\")\n",
    "\n",
    "# Distribution of Estimated Revenue (Summary of Data)\n",
    "plt.figure(figsize=(10, 6))\n",
    "sns.histplot(df[\"log_revenue\"], kde=True, bins=20, color=\"skyblue\")\n",
    "median_val = df[\"log_revenue\"].median()\n",
    "plt.axvline(median_val, color=\"red\", linestyle=\"--\", label=f\"Median: {median_val:.2f}\")\n",
    "plt.title(\"Distribution of Estimated Revenue (Log10 Scale)\")\n",
    "plt.xlabel(\"Log10(Estimated Revenue + 1)\")\n",
    "plt.ylabel(\"Frequency\")\n",
    "plt.legend()\n",
    "plt.savefig(\"results/revenue_distribution.png\")\n",
    "plt.show()\n",
    "\n",
    "print(\"This is an overview of the games' revenue. Shooter revenue has a very small number of games that make a lot of money, but\")\n",
    "print(\"most make next to nothing. This distribution proves that Hypothesis 1 (Revenue) cannot be tested using simple averages;\")\n",
    "print(\"it requires log-linear models. Since success is an outlier, we can better justify why search interest might only correlate\")\n",
    "print(\"weakly with the entire dataset but could be vital for predicting the performance of those at the top.\")\n",
    "\n",
    "# Hypothesis 1: Search Interest vs Revenue\n",
    "plt.figure(figsize=(10, 6))\n",
    "sns.scatterplot(data=df_search_active, x=\"log_search\", y=\"log_revenue\", hue=\"is_free\", alpha=0.6)\n",
    "sns.regplot(data=df_search_active[df_search_active[\"is_free\"]==True], x=\"log_search\", y=\"log_revenue\", scatter=False, color=\"orange\", label=\"F2P Trend\")\n",
    "sns.regplot(data=df_search_active[df_search_active[\"is_free\"]==False], x=\"log_search\", y=\"log_revenue\", scatter=False, color=\"blue\", label=\"Paid Trend\")\n",
    "plt.title(\"Search Interest vs. Estimated Revenue\")\n",
    "plt.xlabel(\"Log10(Search Interest)\")\n",
    "plt.ylabel(\"Log10(Estimated Revenue)\")\n",
    "plt.legend(title=\"Is Free-to-Play?\")\n",
    "plt.savefig(\"results/search_vs_revenue.png\")\n",
    "plt.show()\n",
    "\n",
    "print(\"Hypothesis 1: We can see that paid games show a steeper (less flat) relationship between search interest and revenue than\")\n",
    "print(\"free games. This supports the nuance in Hypothesis 1: Search interest translates directly to sales for paid games. But\")\n",
    "print(\"for free games, revenue is more detached from pre-launch interest and more dependent on post-launch volume (CCU).\")\n",
    "\n",
    "# 3. CCU vs Retention\n",
    "plt.figure(figsize=(10, 6))\n",
    "sns.scatterplot(data=df_retention_active, x=\"log_ccu\", y=\"log_retention\", hue=\"is_free\", alpha=0.6)\n",
    "sns.regplot(data=df_retention_active, x=\"log_ccu\", y=\"log_retention\", scatter=False, color=\"black\")\n",
    "plt.title(\"Peak CCU vs. Player Retention\")\n",
    "plt.xlabel(\"Log10(Peak CCU)\")\n",
    "plt.ylabel(\"Log10(Player Retention)\")\n",
    "plt.savefig(\"results/ccu_vs_retention.png\")\n",
    "plt.show()\n",
    "\n",
    "print(\"Hypothesis 1: This graph shows that success in free games is strongly correlated with CCU, meaning CCU is a better predictor\")\n",
    "print(\"than search interest.\")\n",
    "\n",
    "# Hypothesis 2: Price vs Retention\n",
    "plt.figure(figsize=(10, 6))\n",
    "sns.scatterplot(data=df_retention_active, x=\"initialprice\", y=\"log_retention\", alpha=0.6, color=\"green\")\n",
    "sns.regplot(data=df_retention_active, x=\"initialprice\", y=\"log_retention\", scatter=False, color=\"darkgreen\")\n",
    "plt.title(\"Initial Price vs. Player Retention\")\n",
    "plt.xlabel(\"Initial Price ($)\")\n",
    "plt.ylabel(\"Log10(Average 2-week Playtime + 1)\")\n",
    "plt.savefig(\"results/price_vs_retention.png\")\n",
    "plt.show()\n",
    "\n",
    "print(\"Hypothesis 2: The positive slope shows that games with a higher initial price tend to have higher average playtime.\")\n",
    "print(\"The investment cost fosters a more dedicated player base.\")\n",
    "\n",
    "# Hypothesis 3: Interaction vs Reception\n",
    "plt.figure(figsize=(10, 6))\n",
    "sns.scatterplot(data=df, x=\"price_category_interaction\", y=\"community_reception\", size=\"log_ccu\", alpha=0.6, sizes=(20, 200))\n",
    "sns.regplot(data=df, x=\"price_category_interaction\", y=\"community_reception\", scatter=False, color=\"red\")\n",
    "plt.title(\"Price-Feature Interaction vs. Community Reception\")\n",
    "plt.xlabel(\"Initial Price * Categories Count\")\n",
    "plt.ylabel(\"Positive Review %\")\n",
    "plt.savefig(\"results/interaction_vs_reception.png\")\n",
    "plt.show()\n",
    "\n",
    "print(\"Hypothesis 3: For predicting final positive review percentage, CCU has been added as size encoding. Because the final positive\")\n",
    "print(\"review percentage may be highly skewed for games with an extremely low number of reviews, we can look at the largest dots\")\n",
    "print(\"representing the most successful games. They have clustered towards the middle-top to top-right of the graph, so can conclude\")\n",
    "print(\"that high-investment games with more price and features without high reception are virtually nonexistent.\")\n",
    "\n",
    "# Log-transformed Correlation Heatmap\n",
    "plt.figure(figsize=(10, 8))\n",
    "log_cols = [\"log_search\", \"log_ccu\", \"initialprice\", \"categories_count\", \"log_revenue\", \"community_reception\", \"log_retention\"]\n",
    "log_corr = df[log_cols].corr()\n",
    "sns.heatmap(log_corr, annot=True, cmap=\"coolwarm\", fmt=\".2f\")\n",
    "plt.title(\"Correlation Heatmap (Log-Transformed)\")\n",
    "plt.savefig(\"results/log_correlation_heatmap.png\")\n",
    "plt.show()\n",
    "\n",
    "print(\"The heatmap summarizes correlations between all the log-transformed variables.\")"
