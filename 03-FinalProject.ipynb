    "# 3.1 Create interaction term and analyze\n",
    "print(\"\\n--- Interaction Effect Analysis ---\")\n",
    "\n",
    "# Create price and feature levels using pd.cut\n",
    "if len(df) >= 3:\n",
    "    # Use cut with equal width bins \n",
    "    df['price_level'] = pd.cut(df['initialprice'], bins=3, labels=['Low', 'Medium', 'High'])\n",
    "    df['feature_level'] = pd.cut(df['categories_count'], bins=3, labels=['Low', 'Medium', 'High'])\n",
    "    \n",
    "    # Convert to string to avoid categorical issues\n",
    "    df['price_level_str'] = df['price_level'].astype(str)\n",
    "    df['feature_level_str'] = df['feature_level'].astype(str)\n",
    "    \n",
    "    # Create interaction groups using string concatenation\n",
    "    df['price_feature_group'] = df['price_level_str'] + '-' + df['feature_level_str']\n",
    "    \n",
    "    # Calculate average reception by group\n",
    "    reception_by_group = df.groupby('price_feature_group')['community_reception'].agg(['mean', 'std', 'count']).round(3)\n",
    "    print(\"\\nAverage Positive Review % by Price-Feature Combination:\")\n",
    "    print(reception_by_group.sort_values('mean', ascending=False))\n",
    "\n",
    "# 3.2 Test the interaction effect using regression\n",
    "print(\"\\n--- Regression with Interaction Term ---\")\n",
    "X_h3 = df[['initialprice', 'categories_count']].fillna(0)\n",
    "X_h3['interaction'] = X_h3['initialprice'] * X_h3['categories_count']\n",
    "X_h3_const = sm.add_constant(X_h3)\n",
    "y_h3 = df['community_reception'].fillna(0)\n",
    "\n",
    "if len(X_h3) > 5:\n",
    "    model_h3 = sm.OLS(y_h3, X_h3_const).fit()\n",
    "    print(model_h3.summary().tables[1])\n",
    "\n",
    "# 3.3 Compare models with and without interaction\n",
    "print(\"\\n--- Model Comparison: With vs Without Interaction ---\")\n",
    "\n",
    "# Model without interaction\n",
    "X_no_interact = df[['initialprice', 'categories_count']].fillna(0)\n",
    "X_no_interact_const = sm.add_constant(X_no_interact)\n",
    "model_no_interact = sm.OLS(y_h3, X_no_interact_const).fit()\n",
    "\n",
    "# Model with interaction (already fit)\n",
    "if 'model_h3' in locals():\n",
    "    print(\"\\nR² without interaction: {:.4f}\".format(model_no_interact.rsquared))\n",
    "    print(\"R² with interaction: {:.4f}\".format(model_h3.rsquared))\n",
    "    print(\"Improvement: {:.4f}\".format(model_h3.rsquared - model_no_interact.rsquared))\n",
    "\n",
    "    # Likelihood ratio test\n",
    "    lr_stat = 2 * (model_h3.llf - model_no_interact.llf)\n",
    "    lr_p = 1 - stats.chi2.cdf(lr_stat, 1)  # 1 df difference\n",
    "    print(f\"Likelihood ratio test: χ²={lr_stat:.3f}, p={lr_p:.4f}\")\n",
    "\n",
    "# 3.4 Visualize the interaction effect\n",
    "plt.figure(figsize=(12, 6))\n",
    "\n",
    "try:\n",
    "    # Create pivot table with actual values\n",
    "    pivot_data = []\n",
    "    for price_level in ['Low', 'Medium', 'High']:\n",
    "        for feature_level in ['Low', 'Medium', 'High']:\n",
    "            subset = df[(df['price_level_str'] == price_level) & \n",
